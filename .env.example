# Copy this to .env and fill in values

# PostgreSQL connection string
DATABASE_URL="postgresql://npat:npat_secret@localhost:5432/npat_db"

# Server port
PORT=3001

# CORS — the origin of your React dev server (or production URL)
CLIENT_ORIGIN=http://localhost:5173

# (Optional) For production deployments
# NODE_ENV=production

# If Prisma binary download fails (DNS blocked), try this mirror:
# PRISMA_ENGINES_MIRROR=https://binaries.prisma.sh
